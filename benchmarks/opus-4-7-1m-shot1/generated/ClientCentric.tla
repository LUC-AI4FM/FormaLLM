---- MODULE ClientCentric ----
(***************************************************************************)
(* TLA+ specifications of Client Centric Isolation Specification by        *)
(* Crooks et al: https://dl.acm.org/doi/10.1145/3087801.3087802            *)
(*                                                                         *)
(* TLA+ specifications by Tim Soethout (tim.soethout@ing.com) et al:       *)
(* Automated Validation of State-Based Client-Centric Isolation with TLA+: *)
(* https://doi.org/10.1007/978-3-030-67220-1_4                             *)
(***************************************************************************)
EXTENDS Naturals, Sequences, FiniteSets, TLC

CONSTANTS Keys, Values, TxId

InitValue == CHOOSE v : v \notin Values

(***************************************************************************)
(* A database `State` is represented by keys with corresponding values.    *)
(***************************************************************************)
State == [Keys -> Values \cup {InitValue}]

(***************************************************************************)
(* An `Operation` is a read or write of a key and value.                   *)
(***************************************************************************)
Operation == [op: {"read", "write"}, key: Keys, value: Values \cup {InitValue}]

(***************************************************************************)
(* Helpers representing Reads and Writes.                                  *)
(***************************************************************************)
r(k, v) == [op |-> "read",  key |-> k, value |-> v]
w(k, v) == [op |-> "write", key |-> k, value |-> v]

(***************************************************************************)
(* A `Transaction` is a total order of `Operation`s.                       *)
(* Transaction == [ops: Seq(Operation), start: TimeStamp, commit: TimeStamp]
   For simplicity we store start and commit in a lookup function.          *)
(***************************************************************************)
Transaction == [id: TxId, ops: Seq(Operation)]

(***************************************************************************)
(* "An execution e for a set of transactions T is a totally ordered set    *)
(* defined by the pair (Se, -t in T->), where Se is the set of states      *)
(* generated by applying, starting from the system's initial state,        *)
(* a permutation of all the transactions in T."                            *)
(*                                                                         *)
(* resultState is the parentState of the next transaction, but not used    *)
(* in the isolation definitions.                                           *)
(***************************************************************************)
ExecutionElem == [parentState: State, transaction: Transaction]

(***************************************************************************)
(* We represent an `Execution` as a sequence of `Transaction`s with their  *)
(* corresponding parent state.                                             *)
(***************************************************************************)
Execution == Seq(ExecutionElem)

(***************************************************************************)
(* The parent state is the last state in the execution.                    *)
(***************************************************************************)
parentState(execution) == execution[Len(execution)].parentState

(***************************************************************************)
(* The write set of T comprises the keys that T updates:                   *)
(*   WT = {k | w(k, v) in Sigma_T}.                                        *)
(* For simplicity, assume a transaction only writes a key once.            *)
(***************************************************************************)
writeSet(transaction) ==
  { transaction.ops[i].key : i \in { j \in 1..Len(transaction.ops) :
                                     transaction.ops[j].op = "write" } }

readSet(transaction) ==
  { transaction.ops[i].key : i \in { j \in 1..Len(transaction.ops) :
                                     transaction.ops[j].op = "read" } }

(***************************************************************************)
(* Denoting the set of keys in which s and s' differ as Delta(s, s'),      *)
(* we express NO-CONF_T(s) ≡ Delta(s, sp) ∩ W_T = {} .                     *)
(***************************************************************************)
Delta(s, s2) == { k \in Keys : s[k] # s2[k] }

NoConf(transaction, s, sp) == Delta(s, sp) \cap writeSet(transaction) = {}

(***************************************************************************)
(* Given system state and single transaction (seq of operations),          *)
(* determines new state.                                                   *)
(***************************************************************************)
RECURSIVE nextState(_, _)
nextState(state, ops) ==
  IF Len(ops) = 0 THEN state
  ELSE LET op == Head(ops)
           ns == IF op.op = "write" THEN [state EXCEPT ![op.key] = op.value]
                                    ELSE state
       IN nextState(ns, Tail(ops))

(***************************************************************************)
(* Lists all possible permutations of executions given set of transactions *)
(***************************************************************************)
RECURSIVE permutations(_)
permutations(S) ==
  IF S = {} THEN { << >> }
  ELSE UNION { { <<x>> \o p : p \in permutations(S \ {x}) } : x \in S }

(***************************************************************************)
(* Calculate executions: store ExecutionElem in accumulator, calculate     *)
(* next state.                                                             *)
(***************************************************************************)
RECURSIVE buildExecution(_, _, _)
buildExecution(state, txs, acc) ==
  IF Len(txs) = 0 THEN acc
  ELSE LET t == Head(txs)
           elem == [parentState |-> state, transaction |-> t]
           ns == nextState(state, t.ops)
       IN buildExecution(ns, Tail(txs), Append(acc, elem))

executions(initialState, transactions) ==
  { buildExecution(initialState, p, << >>) : p \in permutations(transactions) }

(***************************************************************************)
(* Read states: from which states can the operation read its value.       *)
(* "s -*-> s_p": restrict the valid read states for the operations in T   *)
(* to be no later than sp.                                                 *)
(* By convention, write operations have read states too: for a write op   *)
(* in T, they include all states in Se up to and including T's parent     *)
(* state.                                                                  *)
(***************************************************************************)
readStates(execution, transaction) ==
  LET idx == CHOOSE i \in 1..Len(execution) : execution[i].transaction = transaction
  IN { execution[j].parentState : j \in 1..idx }

(***************************************************************************)
(* A state `s` is complete for `T` in `e` if every operation in `T`       *)
(* can read from `s`.                                                      *)
(***************************************************************************)
isComplete(s, transaction) ==
  \A i \in 1..Len(transaction.ops) :
    LET op == transaction.ops[i]
    IN op.op = "write" \/ s[op.key] = op.value

(***************************************************************************)
(* Serializability commit test.                                            *)
(***************************************************************************)
CT_SER(transaction, execution) ==
  \E s \in readStates(execution, transaction) : isComplete(s, transaction)

(***************************************************************************)
(* Snapshot Isolation.                                                     *)
(***************************************************************************)
CT_SI(transaction, execution) ==
  \E s \in readStates(execution, transaction) :
    /\ isComplete(s, transaction)
    /\ NoConf(transaction, s, parentState(execution))

(***************************************************************************)
(* Read Committed.                                                         *)
(***************************************************************************)
CT_RC(transaction, execution) ==
  \A i \in 1..Len(transaction.ops) :
    transaction.ops[i].op = "write" \/
    \E s \in readStates(execution, transaction) :
      s[transaction.ops[i].key] = transaction.ops[i].value

(***************************************************************************)
(* Read Uncommitted.                                                       *)
(***************************************************************************)
CT_RU(transaction, execution) == TRUE

(***************************************************************************)
(* Tests there exists an execution for `transactions` that satisfies the   *)
(* isolation level given by `commitTest`.                                  *)
(***************************************************************************)
satisfyIsolationLevel(initialState, transactions, commitTest(_,_)) ==
  \E execution \in executions(initialState, transactions) :
    \A transaction \in transactions : commitTest(transaction, execution)

Serializability(initialState, transactions) ==
  satisfyIsolationLevel(initialState, transactions, CT_SER)

SnapshotIsolation(initialState, transactions) ==
  satisfyIsolationLevel(initialState, transactions, CT_SI)

ReadCommitted(initialState, transactions) ==
  satisfyIsolationLevel(initialState, transactions, CT_RC)

ReadUncommitted(initialState, transactions) ==
  satisfyIsolationLevel(initialState, transactions, CT_RU)

(***************************************************************************)
(* Check types in derived specification.                                   *)
(***************************************************************************)
TypeOK ==
  /\ InitValue \notin Values

====
